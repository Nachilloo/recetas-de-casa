# Copia a .env y rellena. En Vercel: Settings → Environment Variables.

# Supabase (ya deberías tenerlas)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

PUBLIC_SITE_URL=https://www.recetasdecasa.es

# Cron: protege /api/pinterest/publish-daily
# Generar: openssl rand -hex 32
CRON_SECRET=

# Pinterest OAuth (NO uses el token "Producción limitada" de 24h)
# Obtener con flujo OAuth: boards:read,boards:write,pins:read,pins:write
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Tablero por defecto (Recetas de Casa)
PINTEREST_BOARD_ID=1104226471077150730
