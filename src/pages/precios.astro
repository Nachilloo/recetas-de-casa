---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";

const baseUrl = import.meta.env.BASE_URL;
const user = Astro.locals.user;
const profile = Astro.locals.profile;

const yaPro = profile?.plan === "pro";
const enTrial =
  profile?.plan === "trial" &&
  !!profile?.trial_ends_at &&
  new Date(profile.trial_ends_at) > new Date();
const trialUsado = !!profile?.trial_used_at;

const features = {
  free: [
    "Acceso completo al recetario",
    "Búsqueda y filtros por categoría y tiempo",
    "Receta del día y novedades",
    "Favoritos y colecciones ilimitadas",
    "1 generación de menú con IA cada 2 meses",
  ],
  pro: [
    "Todo lo del plan gratuito",
    "Menú semanal con IA ilimitado",
    "Aprovechamiento de ingredientes",
    "Productos de temporada",
    "Lista de la compra exportable",
    "Perfil público destacado",
    "Sin anuncios cuando se incorporen",
    "Soporte prioritario",
  ],
};
---

<Layout
  title="Precios"
  description="Plan gratuito para todo el recetario y favoritos. Plan Pro para menú con IA ilimitado, aprovechamiento y temporada. 10 días gratis sin tarjeta."
>
  <Header />
  <main>
    <section class="border-b border-border bg-canvas py-16 sm:py-24">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">Planes</p>
        <h1 class="font-display text-4xl font-semibold leading-tight tracking-tight text-fg sm:text-5xl">
          Cocina abierta. Planificación, opcional.
        </h1>
        <p class="mt-5 text-base leading-relaxed text-fg-muted sm:text-lg">
          El recetario, los favoritos y las colecciones son gratis. Si quieres organizar tu semana
          con IA sin límites, el Plan Pro lo hace por ti.
        </p>
        {!user && (
          <p class="mt-3 text-sm text-fg-subtle">
            <a href={`${baseUrl}registro`} class="font-medium text-accent hover:underline">
              Crea tu cuenta gratis
            </a>{" "}
            para empezar.
          </p>
        )}
      </div>
    </section>

    <section class="bg-surface py-16 sm:py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <div class="grid gap-6 md:grid-cols-2 md:gap-8">
          {/* Plan gratis */}
          <article class="flex flex-col rounded-[var(--radius-lg)] border border-border bg-canvas p-8">
            <header>
              <h2 class="font-display text-2xl font-semibold text-fg">Gratis</h2>
              <p class="mt-1 text-sm text-fg-muted">Para cocinar el día a día sin compromisos.</p>
              <p class="mt-6">
                <span class="font-display text-4xl font-semibold text-fg">0&nbsp;€</span>
                <span class="ml-1 text-sm text-fg-subtle">para siempre</span>
              </p>
            </header>

            <ul class="mt-8 space-y-3 text-sm">
              {features.free.map((f) => (
                <li class="flex items-start gap-3 text-fg">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-accent"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <a
              href={user ? `${baseUrl}recetas/` : `${baseUrl}registro`}
              class="mt-10 inline-flex items-center justify-center rounded-[var(--radius)] border border-border bg-surface px-5 py-3 text-sm font-medium text-fg transition-colors hover:border-accent hover:text-accent"
            >
              {user ? "Ir al recetario" : "Crear cuenta gratis"}
            </a>
          </article>

          {/* Plan Pro */}
          <article class="relative flex flex-col rounded-[var(--radius-lg)] border-2 border-accent bg-canvas p-8 shadow-sm">
            <span class="absolute -top-3 right-6 inline-flex items-center rounded-full bg-accent px-3 py-1 text-xs font-semibold uppercase tracking-wider text-[var(--color-accent-contrast)]">
              {yaPro ? "Tu plan" : enTrial ? "En trial" : "Recomendado"}
            </span>

            <header>
              <h2 class="font-display text-2xl font-semibold text-fg">Pro</h2>
              <p class="mt-1 text-sm text-fg-muted">Para planificar la semana en serio.</p>
              <p class="mt-6">
                <span class="font-display text-4xl font-semibold text-fg">4,99&nbsp;€</span>
                <span class="ml-1 text-sm text-fg-subtle">/ mes</span>
              </p>
              <p class="mt-1 text-xs text-fg-subtle">o 39&nbsp;€ al año (35&nbsp;% de descuento)</p>
              {!yaPro && !enTrial && !trialUsado && (
                <p class="mt-3 inline-flex items-center gap-2 rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-accent">
                  Prueba 10 días gratis sin tarjeta
                </p>
              )}
            </header>

            <ul class="mt-8 space-y-3 text-sm">
              {features.pro.map((f) => (
                <li class="flex items-start gap-3 text-fg">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-accent"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            {yaPro ? (
              <a
                href={`${baseUrl}perfil/plan`}
                class="mt-10 inline-flex items-center justify-center rounded-[var(--radius)] border border-accent bg-surface px-5 py-3 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-[var(--color-accent-contrast)]"
              >
                Gestionar mi plan
              </a>
            ) : !user ? (
              <a
                href={`${baseUrl}registro?next=/perfil/plan`}
                class="mt-10 inline-flex items-center justify-center rounded-[var(--radius)] bg-accent px-5 py-3 text-sm font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover"
              >
                Crear cuenta y probar
              </a>
            ) : enTrial ? (
              <a
                href={`${baseUrl}perfil/plan`}
                class="mt-10 inline-flex items-center justify-center rounded-[var(--radius)] bg-accent px-5 py-3 text-sm font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover"
              >
                Suscribirme antes del fin del trial
              </a>
            ) : trialUsado ? (
              <a
                href={`${baseUrl}perfil/plan`}
                class="mt-10 inline-flex items-center justify-center rounded-[var(--radius)] bg-accent px-5 py-3 text-sm font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover"
              >
                Suscribirme a Pro
              </a>
            ) : (
              <form action={`${baseUrl}api/trial/start`} method="post" class="mt-10">
                <button
                  type="submit"
                  class="inline-flex w-full items-center justify-center rounded-[var(--radius)] bg-accent px-5 py-3 text-sm font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover"
                >
                  Probar Pro 10 días gratis
                </button>
              </form>
            )}
          </article>
        </div>

        <p class="mt-12 text-center text-sm text-fg-subtle">
          Pago con tarjeta a través de Stripe. Cancelas cuando quieras desde tu cuenta.
        </p>
      </div>
    </section>

    <section class="border-t border-border bg-canvas py-16 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <h2 class="font-display text-2xl font-semibold tracking-tight text-fg sm:text-3xl">
          Preguntas frecuentes
        </h2>
        <dl class="mt-10 divide-y divide-border border-y border-border">
          <div class="py-6">
            <dt class="font-medium text-fg">¿Las recetas se vuelven de pago?</dt>
            <dd class="mt-2 text-sm leading-relaxed text-fg-muted">
              No. El recetario completo seguirá siendo gratuito y abierto. El Plan Pro solo añade
              herramientas de planificación con IA y exportación.
            </dd>
          </div>
          <div class="py-6">
            <dt class="font-medium text-fg">¿Cómo funciona la generación gratuita?</dt>
            <dd class="mt-2 text-sm leading-relaxed text-fg-muted">
              Tu cuenta gratuita puede generar un menú semanal con IA cada 2 meses. Si quieres usarlo
              sin límites (más opciones, aprovechamiento, temporada), prueba Pro 10 días gratis.
            </dd>
          </div>
          <div class="py-6">
            <dt class="font-medium text-fg">¿Hace falta tarjeta para el trial?</dt>
            <dd class="mt-2 text-sm leading-relaxed text-fg-muted">
              No. Activas tu trial de 10 días desde tu cuenta sin introducir tarjeta. Al terminar
              vuelves a Gratis automáticamente; si quieres seguir con Pro, te suscribes con tarjeta.
            </dd>
          </div>
          <div class="py-6">
            <dt class="font-medium text-fg">¿Cómo se cobra?</dt>
            <dd class="mt-2 text-sm leading-relaxed text-fg-muted">
              Mensual o anual, con tarjeta a través de Stripe. Sin permanencia y con factura.
            </dd>
          </div>
        </dl>
      </div>
    </section>
  </main>
</Layout>
