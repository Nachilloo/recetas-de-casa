---
import PerfilLayout from "../../layouts/PerfilLayout.astro";
import CuentaForm from "../../components/CuentaForm.tsx";

const user = Astro.locals.user!;
const profile = Astro.locals.profile;
const baseUrl = import.meta.env.BASE_URL;
---

<PerfilLayout
  title="Cuenta"
  description="Tu información pública y privada. Elige un username para activar tu perfil público."
  active="cuenta"
>
  <CuentaForm
    client:load
    baseUrl={baseUrl}
    email={user.email ?? ''}
    initialUsername={profile?.username ?? null}
    initialDisplayName={profile?.display_name ?? ''}
    initialBio={profile?.bio ?? ''}
    initialIsPublic={profile?.is_public ?? false}
  />
</PerfilLayout>
