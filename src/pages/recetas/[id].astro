---
import { supabase } from '../../lib/supabase';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import RecipeSchema from '../../components/RecipeSchema.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import { categorias, dificultades } from '../../content/config';
import { getCategoriasList, primaryCategoria } from '../../lib/recetaCategorias';
import type { Receta } from '../../lib/types';

const { id } = Astro.params;

const { data: recetaRaw, error } = await supabase
  .from('recetas')
  .select('*')
  .eq('slug', id)
  .single();

if (error || !recetaRaw) {
  return Astro.redirect('/404');
}

const receta = recetaRaw as Receta;

const {
  title,
  descripcion,
  imagen,
  imagen_alt,
  tiempo,
  porciones,
  ingredientes,
  pasos,
  tips,
  calorias,
  tags,
  historia,
  dificultad,
  guia_casera,
} = receta;

const listaCategorias = getCategoriasList(receta);
const categoria = primaryCategoria(listaCategorias);
const categoriaNombre = categorias[categoria as keyof typeof categorias] || categoria;
const dificultadNombre = dificultades[dificultad as keyof typeof dificultades] || dificultad;

const getImageSrc = (img: string) =>
  img.startsWith('http') ? img : `${import.meta.env.BASE_URL}${img.replace(/^\//, '')}`;

const baseUrl = import.meta.env.BASE_URL;

const site = Astro.site!;
const homeUrl = new URL(baseUrl, site).href;
const categoryUrl = new URL(
  `${baseUrl}buscar?categoria=${encodeURIComponent(categoria)}`,
  site,
).href;
const recipeUrl = Astro.url.href;

const breadcrumbLd = [
  { name: 'Inicio', item: homeUrl },
  { name: categoriaNombre, item: categoryUrl },
  { name: title, item: recipeUrl },
];

type FaqEntry = { question: string; answer: string };

const faqItems: FaqEntry[] = [
  {
    question: `¿Cuánto tiempo lleva preparar ${title}?`,
    answer: `El tiempo estimado es de ${tiempo}.`,
  },
  {
    question: `¿Para cuántas personas está pensada esta receta?`,
    answer: `La receta rinde para ${porciones} ${porciones === 1 ? 'persona' : 'personas'}.`,
  },
  {
    question: `¿Qué nivel de dificultad tiene ${title}?`,
    answer: `La dificultad indicada es: ${dificultadNombre}.`,
  },
];

if (tips && tips.length > 0) {
  faqItems.push({
    question: `¿Qué consejos ayudan a que ${title} salga mejor?`,
    answer: tips.join(' '),
  });
}
---

<Layout
  title={title}
  description={descripcion || `Aprende a preparar ${title}. Receta casera con ingredientes, pasos detallados y consejos del chef.`}
  image={getImageSrc(imagen)}
  type="article"
>
  <RecipeSchema
    slot="head"
    title={title}
    descripcion={descripcion}
    imagen={getImageSrc(imagen)}
    imagen_alt={imagen_alt}
    tiempo={tiempo}
    porciones={porciones}
    ingredientes={ingredientes}
    pasos={pasos}
    categoria={categoria}
    categoriasClaves={listaCategorias}
    dificultad={dificultad}
    calorias={calorias}
    tags={tags}
    created_at={receta.created_at}
    updated_at={receta.updated_at}
  />
  <BreadcrumbSchema slot="head" items={breadcrumbLd} />
  <FaqSchema slot="head" faqs={faqItems} />
  <Header />

  <main class="min-h-screen bg-canvas">
    {/* Hero detalle: foto + información */}
    <section class="border-b border-border bg-surface">
      <div class="mx-auto max-w-7xl px-4 pb-10 pt-8 sm:px-6 sm:pb-14 sm:pt-10 md:pb-14 md:pt-12">
        <nav aria-label="Migas de pan" class="mb-8 text-sm text-fg-muted md:mb-10">
          <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
            <li>
              <a href={homeUrl} class="text-accent hover:underline">Inicio</a>
            </li>
            <li aria-hidden="true" class="text-fg-subtle">/</li>
            <li>
              <a href={categoryUrl} class="text-accent hover:underline">{categoriaNombre}</a>
            </li>
            <li aria-hidden="true" class="text-fg-subtle">/</li>
            <li>
              <span class="text-fg font-medium" aria-current="page">{title}</span>
            </li>
          </ol>
        </nav>

        <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-2 lg:gap-14">
          <div class="order-2 lg:order-1">
            <figure class="overflow-hidden rounded-[var(--radius-lg)] border border-border bg-canvas">
              <img
                src={getImageSrc(imagen)}
                alt={imagen_alt || title}
                class="h-[360px] w-full object-cover sm:h-[440px] lg:h-[520px]"
              />
            </figure>
          </div>

          <div class="order-1 space-y-6 lg:order-2">
            <div>
              <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-accent">
                {categoriaNombre}
              </p>

              <h1 class="font-display text-4xl font-semibold leading-tight tracking-tight text-fg lg:text-5xl">
                {title}
              </h1>

              {descripcion && (
                <p class="mt-5 text-lg leading-relaxed text-fg-muted">{descripcion}</p>
              )}
            </div>

            <div class="flex flex-wrap items-center gap-2">
              {listaCategorias.filter((c: string) => c !== categoria).map((catKey: string) => (
                <span class="inline-flex items-center rounded-full border border-border bg-canvas px-3 py-1 text-xs font-medium text-fg-muted">
                  {categorias[catKey as keyof typeof categorias] || catKey}
                </span>
              ))}
              <span class="inline-flex items-center rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-accent">
                {dificultadNombre}
              </span>
            </div>

            {/* Métricas en línea, sin emoji */}
            <dl class="grid grid-cols-3 gap-px overflow-hidden rounded-[var(--radius-lg)] border border-border bg-border">
              <div class="bg-surface px-4 py-5 text-center">
                <dt class="text-xs font-medium uppercase tracking-wider text-fg-subtle">Tiempo</dt>
                <dd class="font-display mt-2 text-xl font-semibold text-fg">{tiempo}</dd>
              </div>
              <div class="bg-surface px-4 py-5 text-center">
                <dt class="text-xs font-medium uppercase tracking-wider text-fg-subtle">Porciones</dt>
                <dd class="font-display mt-2 text-xl font-semibold text-fg">{porciones}</dd>
              </div>
              {calorias ? (
                <div class="bg-surface px-4 py-5 text-center">
                  <dt class="text-xs font-medium uppercase tracking-wider text-fg-subtle">Calorías</dt>
                  <dd class="font-display mt-2 text-xl font-semibold text-fg">{calorias}</dd>
                </div>
              ) : (
                <div class="bg-surface px-4 py-5 text-center">
                  <dt class="text-xs font-medium uppercase tracking-wider text-fg-subtle">Dificultad</dt>
                  <dd class="font-display mt-2 text-xl font-semibold text-fg">{dificultadNombre}</dd>
                </div>
              )}
            </dl>

            {tags && tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {tags.map((tag: string) => (
                  <span class="rounded-full bg-canvas px-2.5 py-1 text-xs text-fg-muted">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    {/* Contenido principal */}
    <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-3 lg:gap-12">
        <aside class="lg:col-span-1">
          <div class="sticky top-24 rounded-[var(--radius-lg)] border border-border bg-surface p-6">
            <h2 class="font-display text-2xl font-semibold tracking-tight text-fg">
              Ingredientes
            </h2>
            <p class="mt-1 text-xs uppercase tracking-wider text-fg-subtle">Para {porciones} {porciones === 1 ? 'persona' : 'personas'}</p>

            <ul class="mt-6 space-y-3">
              {ingredientes.map((ingrediente: string) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                  <span class="text-fg leading-relaxed">{ingrediente}</span>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        <div class="space-y-10 lg:col-span-2">
          <div class="rounded-[var(--radius-lg)] border border-border bg-surface p-6 sm:p-8">
            <h2 class="font-display text-2xl font-semibold tracking-tight text-fg sm:text-3xl">
              Preparación
            </h2>

            <ol class="mt-8 space-y-7">
              {pasos.map((paso: string, index: number) => (
                <li class="flex gap-5">
                  <div class="shrink-0">
                    <div class="font-display flex h-10 w-10 items-center justify-center rounded-full border border-accent bg-accent-soft text-base font-semibold text-accent">
                      {index + 1}
                    </div>
                  </div>
                  <p class="flex-1 pt-1.5 text-base leading-relaxed text-fg sm:text-lg">{paso}</p>
                </li>
              ))}
            </ol>
          </div>

          {tips && tips.length > 0 && (
            <div class="rounded-[var(--radius-lg)] border border-border bg-canvas p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Tips</p>
              <h2 class="font-display mt-1 text-2xl font-semibold tracking-tight text-fg">Consejos del chef</h2>

              <ul class="mt-6 space-y-3">
                {tips.map((tip: string) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                    <span class="leading-relaxed text-fg-muted">{tip}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {guia_casera && (
            <div class="rounded-[var(--radius-lg)] border border-border bg-surface p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Notas</p>
              <h2 class="font-display mt-1 text-2xl font-semibold tracking-tight text-fg">Guía casera</h2>

              <div class="mt-6 space-y-4 whitespace-pre-line text-base leading-relaxed text-fg-muted sm:text-lg">
                {guia_casera}
              </div>
            </div>
          )}

          {historia && (
            <div class="rounded-[var(--radius-lg)] border border-border bg-canvas p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Historia</p>
              <h2 class="font-display mt-1 text-2xl font-semibold tracking-tight text-fg">De dónde viene</h2>

              <p class="mt-6 text-base leading-relaxed text-fg-muted sm:text-lg">{historia}</p>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="border-b border-border bg-canvas py-12 sm:py-14" aria-labelledby="faq-heading">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <h2 id="faq-heading" class="font-display text-2xl font-semibold tracking-tight text-fg sm:text-3xl">
          Preguntas frecuentes
        </h2>
        <dl class="mt-8 space-y-8">
          {faqItems.map((faq) => (
            <div>
              <dt class="font-semibold text-fg">{faq.question}</dt>
              <dd class="mt-2 text-base leading-relaxed text-fg-muted">{faq.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    {/* CTA navegación */}
    <section class="border-t border-border bg-surface py-14">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
        <h3 class="font-display text-2xl font-semibold tracking-tight text-fg sm:text-3xl">
          ¿Te ha gustado?
        </h3>
        <p class="mx-auto mt-3 max-w-md text-base text-fg-muted">
          Sigue explorando el recetario por categoría o vuelve al listado completo.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a
            href={`${baseUrl}buscar?categoria=${categoria}`}
            class="inline-flex items-center gap-2 rounded-[var(--radius)] bg-accent px-5 py-3 text-sm font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover"
          >
            Más de {categoriaNombre}
          </a>
          <a
            href={`${baseUrl}recetas/`}
            class="inline-flex items-center gap-2 rounded-[var(--radius)] border border-border bg-canvas px-5 py-3 text-sm font-medium text-fg transition-colors hover:border-accent hover:text-accent"
          >
            Todas las recetas
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
