---
import Layout from "../layouts/Layout.astro";
import AuthForm from "../components/AuthForm.tsx";

const baseUrl = import.meta.env.BASE_URL;

if (Astro.locals.user) {
  return Astro.redirect("/");
}

const errorParam = Astro.url.searchParams.get("error");
---

<Layout
  title="Iniciar sesión"
  description="Accede a tu cuenta de Recetas de Casa para guardar favoritos, crear colecciones y planificar tu menú semanal."
  noindex={true}
>
  <main class="min-h-[calc(100vh-4rem)] bg-canvas py-16 sm:py-24">
    <div class="mx-auto max-w-md px-4 sm:px-6">
      <div class="mb-10 text-center">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">Cuenta</p>
        <h1 class="font-display text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          Iniciar sesión
        </h1>
        <p class="mt-3 text-sm text-fg-muted">
          Bienvenido de vuelta. Tus favoritos y colecciones te esperan.
        </p>
      </div>

      {errorParam && (
        <div
          role="alert"
          class="mb-6 rounded-[var(--radius)] border border-danger/40 bg-danger/10 px-4 py-3 text-sm text-danger"
        >
          {errorParam}
        </div>
      )}

      <AuthForm client:load mode="login" baseUrl={baseUrl} />

      <p class="mt-8 text-center text-sm text-fg-muted">
        ¿Aún no tienes cuenta?
        <a
          href={`${baseUrl}registro`}
          class="font-medium text-accent transition-colors hover:text-accent-hover"
        >
          Crear cuenta
        </a>
      </p>
    </div>
  </main>
</Layout>
