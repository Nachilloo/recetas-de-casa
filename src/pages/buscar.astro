---
import { supabase } from "../lib/supabase";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SearchBox from "../components/SearchBox.astro";
import SearchResults from "../components/SearchResults.astro";
import { categorias } from "../content/config";

const url = Astro.url;
const termino = url.searchParams.get("q") || "";
const categoria = url.searchParams.get("categoria") || "";

// Helper: carga todas las filas paginando (supera el límite de 1000 de Supabase)
async function fetchAll(table: string, select: string, filters?: { categoria?: string; termino?: string }) {
  const PAGE = 1000;
  let all: any[] = [];
  let offset = 0;

  while (true) {
    let q = supabase.from(table).select(select).order('created_at', { ascending: false });

    if (filters?.categoria) {
      q = q.eq('categoria', filters.categoria);
    }
    if (filters?.termino) {
      const t = `%${filters.termino}%`;
      q = q.or(`title.ilike.${t},descripcion.ilike.${t}`);
    }

    q = q.range(offset, offset + PAGE - 1);
    const { data, error } = await q;

    if (error) {
      console.error('Error en fetchAll:', error);
      break;
    }
    if (!data || data.length === 0) break;
    all = all.concat(data);
    if (data.length < PAGE) break;
    offset += PAGE;
  }
  return all;
}

// Buscar recetas por título/descripción en Supabase
const filtros: { categoria?: string; termino?: string } = {};
if (categoria && categoria in categorias) filtros.categoria = categoria;
if (termino.trim()) filtros.termino = termino.trim();

let recetas = await fetchAll('recetas', '*', filtros);

// Búsqueda complementaria en ingredientes y tags (son arrays, se filtran en JS)
if (termino.trim()) {
  const terminoLower = termino.toLowerCase().trim();
  const slugsYa = new Set(recetas.map((r: any) => r.slug));

  const todasRaw = await fetchAll(
    'recetas',
    'slug, ingredientes, tags',
    categoria ? { categoria } : undefined
  );

  const slugsExtra: string[] = [];
  for (const r of todasRaw) {
    if (slugsYa.has(r.slug)) continue;
    const enIng = r.ingredientes?.some((i: string) => i.toLowerCase().includes(terminoLower));
    const enTag = r.tags?.some((t: string) => t.toLowerCase().includes(terminoLower));
    if (enIng || enTag) slugsExtra.push(r.slug);
  }

  if (slugsExtra.length > 0) {
    const { data: extras } = await supabase.from('recetas').select('*').in('slug', slugsExtra);
    if (extras) recetas = recetas.concat(extras);
  }
}

const totalRecetas = recetas.length;

// Contadores de categoría (todos los registros, sin filtro de búsqueda)
const allRecetas = await fetchAll('recetas', 'categoria, created_at');
---

<Layout
  title={termino ? `Buscar: ${termino}` : "Buscar Recetas"}
  description={termino 
    ? `Resultados de búsqueda para "${termino}". Encuentra recetas caseras españolas con ${termino}.`
    : "Busca entre nuestra colección de recetas caseras españolas. Filtra por ingredientes, categorías o nombres."
  }
  noindex={true}
>
  <Header title="Buscar Recetas" />

  <main class="max-w-7xl mx-auto px-6 py-8">
    <!-- Buscador principal -->
    <section class="mb-8">
      <div class="max-w-2xl mx-auto">
        <SearchBox
          placeholder="Buscar por ingrediente, nombre, descripción..."
          size="lg"
          className="mb-6"
        />

        <!-- Búsquedas rápidas -->
        <div class="text-center">
          <p class="text-sm text-gray-600 mb-3">Búsquedas populares:</p>
          <div class="flex flex-wrap justify-center gap-2">
            <a
              href="/buscar?q=chocolate"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              chocolate
            </a>
            <a
              href="/buscar?q=pasta"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              pasta
            </a>
            <a
              href="/buscar?q=crema"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              crema
            </a>
            <a
              href="/buscar?q=huevos"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              huevos
            </a>
            <a
              href="/buscar?q=arroz"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              arroz
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Filtros por categoría -->
    <section class="mb-8">
      <h3 class="text-xl font-bold text-gray-900 mb-4">
         Filtrar por Categoría
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3">
        {
          Object.entries(categorias).map(([key, nombre]) => {
            const recetasEnCategoria = allRecetas.filter(
              (r) => r.categoria === key
            );
            const iconos: { [key: string]: string } = {
              "arroz-paellas": "🥘",
              "tortillas-pasta": "🥚",
              "sopas-cremas": "🍲",
              "carnes-aves": "🍖",
              "pescados-mariscos": "🐟",
              "pan-masas": "🥖",
              postres: "🍰",
              "ensaladas-tapas": "🥗",
            };

            const isActive = categoria === key;
            const href = isActive
              ? `/buscar${termino ? `?q=${encodeURIComponent(termino)}` : ""}`
              : `/buscar?categoria=${key}${termino ? `&q=${encodeURIComponent(termino)}` : ""}`;
            return (
              <a
                href={href}
                class={`group border rounded-xl p-3 text-center transition-all duration-200 hover:-translate-y-1 hover:shadow-md ${
                  isActive
                    ? "bg-orange-100 border-orange-300 text-orange-800"
                    : "bg-white hover:bg-orange-50 border-gray-200 hover:border-orange-300"
                }`}
              >
                <div class="text-2xl mb-1 group-hover:scale-110 transition-transform duration-200">
                  {iconos[key] || "🍽️"}
                </div>
                <div class="text-xs font-medium mb-1 line-clamp-2">
                  {nombre}
                </div>
                <div class="text-xs text-gray-500">
                  {recetasEnCategoria.length}
                </div>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- Resultados -->
    <SearchResults
      recetas={recetas}
      termino={termino}
      categoria={categoria}
      totalRecetas={totalRecetas}
    />
  </main>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
