---
import { supabase } from "../lib/supabase";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SearchBox from "../components/SearchBox.astro";
import SearchResults from "../components/SearchResults.astro";
import TiempoQuickLinks from "../components/TiempoQuickLinks.astro";
import { categorias } from "../content/config";
import { recetaTieneCategoria } from "../lib/recetaCategorias";
import {
  normalizaFiltroTiempo,
  recetaCoincideFiltroTiempo,
} from "../lib/recetaTiempo";
import { buscarHref, TEXTO_FILTRO_TIEMPO } from "../lib/buscarQuery";

const url = Astro.url;
const termino = url.searchParams.get("q") || "";
const categoria = url.searchParams.get("categoria") || "";
const tiempoFiltro = normalizaFiltroTiempo(url.searchParams.get("tiempo"));

const tiempoLabel = TEXTO_FILTRO_TIEMPO;

/** Listado compacto (cards); evita select('*') — menos JSON y menos RAM en Vercel. */
const SEL_LISTADO_BUSCAR =
  "slug, title, imagen, imagen_alt, tiempo, porciones, dificultad, categoria, categorias, created_at";
const SEL_CONTADORES_CAT = "categoria, categorias, created_at";
const SEL_ING_TAGS = "slug, ingredientes, tags";

/** Vista /buscar sin filtros: listado ligero (no descargar ~1500 filas). */
const MUESTRA_LISTADO = 10;
const MUESTRA_POOL_MAX = 80;

const categoriaValida =
  categoria && categoria in categorias ? categoria : "";
const tieneBusquedaTexto = Boolean(termino.trim());
const tieneFiltroCategoria = Boolean(categoriaValida);

// Helper: carga todas las filas paginando (supera el límite de 1000 de Supabase)
async function fetchAll(table: string, select: string, filters?: { categoria?: string; termino?: string }) {
  const PAGE = 1000;
  let all: any[] = [];
  let offset = 0;

  while (true) {
    let q = supabase.from(table).select(select).order('created_at', { ascending: false });

    if (filters?.categoria) {
      const k = filters.categoria;
      q = q.or(`categoria.eq.${k},categorias.cs.{${k}}`);
    }
    if (filters?.termino) {
      const t = `%${filters.termino}%`;
      q = q.or(`title.ilike.${t},descripcion.ilike.${t}`);
    }

    q = q.range(offset, offset + PAGE - 1);
    const { data, error } = await q;

    if (error) {
      console.error('Error en fetchAll:', error);
      break;
    }
    if (!data || data.length === 0) break;
    all = all.concat(data);
    if (data.length < PAGE) break;
    offset += PAGE;
  }
  return all;
}

/** Ventana aleatoria sobre el listado ordenado + mezcla (sin RPC). */
async function fetchRecetasMuestraAleatoria(select: string): Promise<any[]> {
  const { count, error: cErr } = await supabase
    .from("recetas")
    .select("slug", { count: "exact", head: true });

  if (cErr || count === null || count === 0) {
    if (cErr) console.error("[buscar] count recetas", cErr);
    return [];
  }

  const pool = Math.min(MUESTRA_POOL_MAX, count);
  const maxOff = Math.max(0, count - pool);
  const off = Math.floor(Math.random() * (maxOff + 1));

  const { data, error } = await supabase
    .from("recetas")
    .select(select)
    .order("created_at", { ascending: false })
    .range(off, off + pool - 1);

  if (error) {
    console.error("[buscar] muestra aleatoria", error);
    return [];
  }
  if (!data?.length) return [];

  const shuffled = [...data];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  const take = Math.min(MUESTRA_LISTADO, shuffled.length);
  return shuffled.slice(0, take);
}

const filtros: { categoria?: string; termino?: string } = {};
if (tieneFiltroCategoria) filtros.categoria = categoriaValida;
if (tieneBusquedaTexto) filtros.termino = termino.trim();

let recetas: any[] = [];
let allRecetas: any[] = [];
let esVistaMuestra = false;

if (!tieneBusquedaTexto && !tieneFiltroCategoria && tiempoFiltro === "all") {
  esVistaMuestra = true;
  Astro.response.headers.set(
    "Cache-Control",
    "private, no-store, must-revalidate"
  );
  [allRecetas, recetas] = await Promise.all([
    fetchAll("recetas", SEL_CONTADORES_CAT),
    fetchRecetasMuestraAleatoria(SEL_LISTADO_BUSCAR),
  ]);
} else if (!tieneBusquedaTexto && !tieneFiltroCategoria) {
  allRecetas = await fetchAll("recetas", SEL_LISTADO_BUSCAR);
  recetas = allRecetas;
} else {
  [recetas, allRecetas] = await Promise.all([
    fetchAll("recetas", SEL_LISTADO_BUSCAR, filtros),
    fetchAll("recetas", SEL_CONTADORES_CAT),
  ]);
}

// Búsqueda complementaria en ingredientes y tags (arrays; en JS)
if (tieneBusquedaTexto) {
  const terminoLower = termino.toLowerCase().trim();
  const slugsYa = new Set(recetas.map((r: any) => r.slug));

  const todasRaw = await fetchAll(
    "recetas",
    SEL_ING_TAGS,
    tieneFiltroCategoria ? { categoria: categoriaValida } : undefined
  );

  const slugsExtra: string[] = [];
  for (const r of todasRaw) {
    if (slugsYa.has(r.slug)) continue;
    const enIng = r.ingredientes?.some((i: string) =>
      i.toLowerCase().includes(terminoLower)
    );
    const enTag = r.tags?.some((t: string) =>
      t.toLowerCase().includes(terminoLower)
    );
    if (enIng || enTag) slugsExtra.push(r.slug);
  }

  if (slugsExtra.length > 0) {
    const { data: extras } = await supabase
      .from("recetas")
      .select(SEL_LISTADO_BUSCAR)
      .in("slug", slugsExtra);
    if (extras) recetas = recetas.concat(extras);
  }
}

if (tiempoFiltro !== "all") {
  recetas = recetas.filter((r: { tiempo?: string }) =>
    recetaCoincideFiltroTiempo(r.tiempo, tiempoFiltro)
  );
}

const totalRecetas = recetas.length;

const resultadoPartes = [
  termino.trim() ? `"${termino.trim()}"` : null,
  categoria && categoria in categorias
    ? categorias[categoria as keyof typeof categorias]
    : null,
  tiempoFiltro !== "all" ? tiempoLabel[tiempoFiltro] : null,
].filter(Boolean) as string[];

const metaTitle =
  resultadoPartes.length > 0
    ? `Buscar: ${resultadoPartes.join(" · ")}`
    : termino.trim()
      ? `Buscar: ${termino.trim()}`
      : "Buscar Recetas";

const metaDescription =
  resultadoPartes.length > 0
    ? `Recetas caseras (${resultadoPartes.join(" · ")}). Filtra por nombre, ingrediente o tiempo.`
    : termino.trim()
      ? `Resultados para "${termino.trim()}". Recetas españolas por ingredientes y categorías.`
      : "Busca recetas caseras españolas por texto, categoría y tiempo de cocina.";
---

<Layout
  title={metaTitle}
  description={metaDescription}
  noindex={true}
>
  <Header />

  <main class="bg-canvas">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 md:py-14">
      <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-fg-subtle">Recetario</p>
      <h1 class="font-display text-3xl font-semibold tracking-tight text-fg md:text-4xl mb-8">Buscar recetas</h1>

      <section class="mb-10">
        <div class="max-w-2xl mx-auto">
          <SearchBox
            placeholder="Buscar por ingrediente, nombre, descripción…"
            size="lg"
            className="mb-4"
            requireQuery={false}
            initialQuery={termino}
            tiempoFiltro={tiempoFiltro}
            categoriaFiltro={categoriaValida}
          />
          <p class="text-center text-xs uppercase tracking-wider text-fg-subtle mb-2">Tiempo de cocina</p>
          <TiempoQuickLinks
            termino={termino}
            categoria={categoriaValida}
            tiempoActivo={tiempoFiltro}
            className="mb-8"
          />

          <div class="text-center">
            <p class="text-sm text-fg-muted mb-3">Búsquedas populares</p>
            <div class="flex flex-wrap justify-center gap-2">
              {['chocolate', 'pasta', 'crema', 'huevos', 'arroz'].map((termGuess) => (
                <a
                  href={buscarHref({ termino: termGuess, tiempo: tiempoFiltro })}
                  class="rounded-full border border-border bg-surface px-3 py-1 text-xs text-fg-muted transition-colors hover:border-accent hover:text-accent"
                >
                  {termGuess}
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="mb-10">
        <h3 class="font-display text-xl font-semibold text-fg mb-4">
          Filtrar por categoría
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3">
          {
            Object.entries(categorias).map(([key, nombre]) => {
              const recetasEnCategoria = allRecetas.filter((r) =>
                recetaTieneCategoria(r, key)
              );
              const isActive = categoria === key;
              const href = isActive
                ? buscarHref({ termino, tiempo: tiempoFiltro })
                : buscarHref({ termino, categoria: key, tiempo: tiempoFiltro });
              return (
                <a
                  href={href}
                  class={`block rounded-[var(--radius-lg)] border p-4 text-center transition-colors ${
                    isActive
                      ? 'border-accent bg-accent-soft text-accent'
                      : 'border-border bg-surface text-fg hover:border-accent hover:text-accent'
                  }`}
                >
                  <div class="text-sm font-medium mb-1 line-clamp-2">
                    {nombre}
                  </div>
                  <div class="text-xs text-fg-subtle tabular-nums">
                    {recetasEnCategoria.length}
                  </div>
                </a>
              );
            })
          }
        </div>
      </section>

      <SearchResults
        recetas={recetas}
        termino={termino}
        categoria={categoriaValida}
        tiempoFiltro={tiempoFiltro}
        totalRecetas={totalRecetas}
        esVistaMuestra={esVistaMuestra}
      />
    </div>
  </main>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
