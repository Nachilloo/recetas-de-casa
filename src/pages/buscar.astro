---
import { supabase } from "../lib/supabase";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SearchBox from "../components/SearchBox.astro";
import SearchResults from "../components/SearchResults.astro";
import { categorias } from "../content/config";

const url = Astro.url;
const termino = url.searchParams.get("q") || "";
const categoria = url.searchParams.get("categoria") || "";

// Búsqueda directa en Supabase (sin límite de 1000)
let query = supabase.from('recetas').select('*');

if (categoria && categoria in categorias) {
  query = query.eq('categoria', categoria);
}

query = query.order('created_at', { ascending: false });

if (termino.trim()) {
  const t = `%${termino.trim()}%`;
  query = query.or(`title.ilike.${t},descripcion.ilike.${t}`);
}

// Paginar para traer todas (superar límite de 1000)
let recetas: any[] = [];
let offset = 0;
const PAGE = 1000;
while (true) {
  const { data, error } = await query.range(offset, offset + PAGE - 1);
  if (error) {
    console.error('Error al buscar recetas:', error);
    break;
  }
  if (!data || data.length === 0) break;
  recetas = recetas.concat(data);
  if (data.length < PAGE) break;
  offset += PAGE;
}

// Si hay término, búsqueda adicional en ingredientes y tags (arrays, en JS)
if (termino.trim()) {
  const terminoLower = termino.toLowerCase().trim();
  
  // Cargar todas las recetas con solo los campos necesarios para buscar en arrays
  let todasRaw: any[] = [];
  let off2 = 0;
  let q2 = supabase.from('recetas').select('slug, title, ingredientes, tags').order('created_at', { ascending: false });
  if (categoria && categoria in categorias) {
    q2 = q2.eq('categoria', categoria);
  }
  while (true) {
    const { data: d2 } = await q2.range(off2, off2 + PAGE - 1);
    if (!d2 || d2.length === 0) break;
    todasRaw = todasRaw.concat(d2);
    if (d2.length < PAGE) break;
    off2 += PAGE;
  }

  // Buscar en ingredientes y tags
  const slugsYaEncontrados = new Set(recetas.map((r: any) => r.slug));
  const slugsExtra = new Set<string>();
  
  for (const r of todasRaw) {
    if (slugsYaEncontrados.has(r.slug)) continue;
    const enIngredientes = r.ingredientes?.some((ing: string) => ing.toLowerCase().includes(terminoLower));
    const enTags = r.tags?.some((tag: string) => tag.toLowerCase().includes(terminoLower));
    if (enIngredientes || enTags) {
      slugsExtra.add(r.slug);
    }
  }

  // Cargar recetas completas de los extras encontrados
  if (slugsExtra.size > 0) {
    const { data: extras } = await supabase
      .from('recetas')
      .select('*')
      .in('slug', [...slugsExtra]);
    if (extras) {
      recetas = recetas.concat(extras);
    }
  }
}

const totalRecetas = recetas.length;

// Para los contadores de categoría
let allRecetas: any[] = [];
let off3 = 0;
while (true) {
  const { data: d3 } = await supabase.from('recetas').select('categoria').range(off3, off3 + PAGE - 1);
  if (!d3 || d3.length === 0) break;
  allRecetas = allRecetas.concat(d3);
  if (d3.length < PAGE) break;
  off3 += PAGE;
}
---

<Layout
  title={termino ? `Buscar: ${termino}` : "Buscar Recetas"}
  description={termino 
    ? `Resultados de búsqueda para "${termino}". Encuentra recetas caseras españolas con ${termino}.`
    : "Busca entre nuestra colección de recetas caseras españolas. Filtra por ingredientes, categorías o nombres."
  }
  noindex={true}
>
  <Header title="Buscar Recetas" />

  <main class="max-w-7xl mx-auto px-6 py-8">
    <!-- Buscador principal -->
    <section class="mb-8">
      <div class="max-w-2xl mx-auto">
        <SearchBox
          placeholder="Buscar por ingrediente, nombre, descripción..."
          size="lg"
          className="mb-6"
        />

        <!-- Búsquedas rápidas -->
        <div class="text-center">
          <p class="text-sm text-gray-600 mb-3">Búsquedas populares:</p>
          <div class="flex flex-wrap justify-center gap-2">
            <a
              href="/buscar?q=chocolate"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              chocolate
            </a>
            <a
              href="/buscar?q=pasta"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              pasta
            </a>
            <a
              href="/buscar?q=crema"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              crema
            </a>
            <a
              href="/buscar?q=huevos"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              huevos
            </a>
            <a
              href="/buscar?q=arroz"
              class="text-xs bg-gray-100 hover:bg-orange-100 text-gray-700 hover:text-orange-700 px-3 py-1 rounded-full transition-colors duration-200"
            >
              arroz
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Filtros por categoría -->
    <section class="mb-8">
      <h3 class="text-xl font-bold text-gray-900 mb-4">
         Filtrar por Categoría
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3">
        {
          Object.entries(categorias).map(([key, nombre]) => {
            const recetasEnCategoria = allRecetas.filter(
              (r) => r.categoria === key
            );
            const iconos: { [key: string]: string } = {
              "arroz-paellas": "🥘",
              "tortillas-pasta": "🥚",
              "sopas-cremas": "🍲",
              "carnes-aves": "🍖",
              "pescados-mariscos": "🐟",
              "pan-masas": "🥖",
              postres: "🍰",
              "ensaladas-tapas": "🥗",
            };

            const isActive = categoria === key;
            const href = isActive
              ? `/buscar${termino ? `?q=${encodeURIComponent(termino)}` : ""}`
              : `/buscar?categoria=${key}${termino ? `&q=${encodeURIComponent(termino)}` : ""}`;
            return (
              <a
                href={href}
                class={`group border rounded-xl p-3 text-center transition-all duration-200 hover:-translate-y-1 hover:shadow-md ${
                  isActive
                    ? "bg-orange-100 border-orange-300 text-orange-800"
                    : "bg-white hover:bg-orange-50 border-gray-200 hover:border-orange-300"
                }`}
              >
                <div class="text-2xl mb-1 group-hover:scale-110 transition-transform duration-200">
                  {iconos[key] || "🍽️"}
                </div>
                <div class="text-xs font-medium mb-1 line-clamp-2">
                  {nombre}
                </div>
                <div class="text-xs text-gray-500">
                  {recetasEnCategoria.length}
                </div>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- Resultados -->
    <SearchResults
      recetas={recetasEncontradas}
      termino={termino}
      categoria={categoria}
      totalRecetas={totalRecetas}
    />
  </main>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
