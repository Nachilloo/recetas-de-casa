---
import Layout from '../layouts/Layout.astro';
import MenuSemanalApp from '../components/MenuSemanal.tsx';
---

<Layout
  title="Menú Semanal"
  description="Genera un menú semanal equilibrado y personalizado con nuestras recetas caseras. Nutrición inteligente con IA."
>
  <main class="min-h-screen bg-canvas">
    <section class="border-b border-border bg-surface py-14 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">Beta</p>
        <h1 class="font-display text-4xl font-semibold leading-tight tracking-tight text-fg sm:text-5xl">
          Menú semanal inteligente
        </h1>
        <p class="mt-5 text-base leading-relaxed text-fg-muted sm:text-lg">
          Genera un menú equilibrado y personalizado para la semana. Combinamos recetas del recetario
          según lo que tengas y lo que quieras comer.
        </p>
      </div>
    </section>

    <MenuSemanalApp client:load />
  </main>
</Layout>
