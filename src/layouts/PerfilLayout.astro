---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description?: string;
  active: "favoritos" | "colecciones" | "cuenta" | "plan";
}

const { title, description, active } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const tabs: { id: Props["active"]; label: string; href: string }[] = [
  { id: "favoritos", label: "Favoritos", href: `${baseUrl}perfil/favoritos` },
  { id: "colecciones", label: "Colecciones", href: `${baseUrl}perfil/colecciones` },
  { id: "cuenta", label: "Cuenta", href: `${baseUrl}perfil/cuenta` },
  { id: "plan", label: "Plan", href: `${baseUrl}perfil/plan` },
];
---

<Layout title={title} description={description} noindex>
  <Header />
  <main class="bg-canvas">
    <section class="border-b border-border bg-surface">
      <div class="mx-auto max-w-5xl px-4 pt-10 sm:px-6 sm:pt-14">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">Mi cuenta</p>
        <h1 class="font-display text-3xl font-semibold tracking-tight text-fg sm:text-4xl">
          {title}
        </h1>
        {description && <p class="mt-3 max-w-2xl text-base text-fg-muted">{description}</p>}

        <nav class="mt-8 flex gap-1 overflow-x-auto" aria-label="Secciones de perfil">
          {tabs.map((tab) => (
            <a
              href={tab.href}
              class:list={[
                "shrink-0 rounded-t-lg px-4 py-2.5 text-sm font-medium transition-colors",
                tab.id === active
                  ? "border-b-2 border-accent text-accent"
                  : "border-b-2 border-transparent text-fg-muted hover:text-accent",
              ]}
              aria-current={tab.id === active ? "page" : undefined}
            >
              {tab.label}
            </a>
          ))}
        </nav>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-14">
      <slot />
    </section>
  </main>
</Layout>
