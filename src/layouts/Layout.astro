---
// Importar el CSS global aquí
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { sitePageUrl } from '../lib/siteUrl';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  /** Oculta pie (p. ej. zona /admin) */
  hideFooter?: boolean;
  /** Oculta cabecera pública del sitio (p. ej. /admin/*) */
  hideHeader?: boolean;
}

const {
  title,
  description = 'Descubre deliciosas recetas caseras de la cocina española. Platos tradicionales, postres, tapas y mucho más para cocinar en casa.',
  image = '/images/hero-ingredientes-1024.webp',
  canonicalUrl,
  type = 'website',
  noindex = false,
  hideFooter = false,
  hideHeader = false,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const currentUrl = sitePageUrl(
  Astro.site,
  Astro.url.pathname,
  Astro.url.search,
  canonicalUrl,
);
const fullImageUrl = image.startsWith('http') ? image : `${siteUrl}${image.startsWith('/') ? '' : '/'}${image}`;
const siteName = 'Recetas de Casa';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
/** Base con barra final para rutas en `public/` (favicons, manifest). */
const assetBase = import.meta.env.BASE_URL.replace(/\/?$/, '') + '/';
---

<!doctype html>
<html lang="es" data-theme="dark" class="min-h-screen bg-canvas">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light dark" />
		<!-- Favicons: .ico para compatibilidad; PNG 96px para UI moderna; Apple; Web App Manifest -->
		<link rel="icon" href={`${assetBase}favicon.ico`} sizes="any" />
		<link rel="icon" type="image/png" sizes="96x96" href={`${assetBase}favicon-96x96.png`} />
		<link rel="apple-touch-icon" href={`${assetBase}apple-touch-icon.png`} />
		<link rel="manifest" href={`${assetBase}site.webmanifest`} />

		{/* Fondo canvas antes del CSS compilado (evita flash en primera carga). */}
		<style is:inline>
			html { background-color: #0f0f0e; }
			html[data-theme="light"] { background-color: #fafaf8; }
		</style>

		{/* Anti-flash: aplica el tema guardado antes del primer paint. */}
		<script is:inline>
			(function () {
				try {
					var t = localStorage.getItem("theme");
					document.documentElement.setAttribute(
						"data-theme",
						t === "light" ? "light" : "dark"
					);
				} catch (e) {
					document.documentElement.setAttribute("data-theme", "dark");
				}
			})();
		</script>

		<!-- Primary Meta Tags -->
		<title>{fullTitle}</title>
		<meta name="title" content={fullTitle} />
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		
		<!-- Canonical URL -->
		<link rel="canonical" href={currentUrl} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={fullImageUrl} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content="es_ES" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={currentUrl} />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={fullImageUrl} />
		
		<!-- Additional SEO -->
		<meta name="author" content={siteName} />
		<meta name="theme-color" content="#fafaf8" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0f0f0e" media="(prefers-color-scheme: dark)" />

		<!-- Slot for page-specific head content (like JSON-LD) -->
		<slot name="head" />
		<Analytics />
	</head>
	<body class="min-h-screen bg-canvas font-sans text-fg antialiased flex flex-col">
		<div class="flex-1 flex flex-col">
			{!hideHeader && <Header />}
			<slot />
		</div>
		{!hideFooter && <Footer />}
	</body>
</html>

<style>
	html {
		margin: 0;
		width: 100%;
	}
</style>
