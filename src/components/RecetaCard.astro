---
import type { Receta } from '../lib/types';
import { categorias as categoriasNombres } from '../content/config';
import { getCategoriasList, primaryCategoria } from '../lib/recetaCategorias';

export interface Props {
  receta: Receta | any;
}

const { receta } = Astro.props;

const isSupabase = 'slug' in receta && !('data' in receta);
const slug = isSupabase ? receta.slug : receta.slug;
const data = isSupabase ? receta : receta.data;

const {
  title,
  descripcion,
  imagen,
  imagen_alt,
  imagenAlt,
  tiempo,
  porciones,
  dificultad,
  tags,
  calorias,
} = data;

const cats = getCategoriasList(data);
const catPrimary = primaryCategoria(cats);
const nombreCategoria =
  categoriasNombres[catPrimary as keyof typeof categoriasNombres] || catPrimary;
const tambienAirFryer = cats.includes('air-fryer') && catPrimary !== 'air-fryer';

const alt = imagen_alt || imagenAlt;

const baseUrl = import.meta.env.BASE_URL;

const getImageSrc = (img: string) =>
  img.startsWith('http') ? img : `${baseUrl}${img.replace(/^\//, '')}`;

const dificultadLabel =
  dificultad === 'facil' ? 'Fácil' : dificultad === 'media' ? 'Media' : 'Difícil';
---

<article class="group h-full overflow-hidden rounded-[var(--radius-lg)] border border-border bg-surface transition-colors hover:border-accent">
  <a href={`${baseUrl}recetas/${slug}/`} class="block h-full">
    <div class="relative">
      <img
        src={getImageSrc(imagen)}
        alt={alt || title}
        class="h-52 w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
        loading="lazy"
      />
      <div class="absolute right-3 top-3 inline-flex items-center gap-1 rounded-full bg-surface/95 px-2.5 py-1 text-xs font-medium text-fg shadow-sm backdrop-blur-sm">
        <svg class="h-3.5 w-3.5 text-fg-muted" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="9" stroke-linecap="round" stroke-linejoin="round"></circle>
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 2"></path>
        </svg>
        {tiempo}
      </div>
    </div>

    <div class="p-5">
      <p class="mb-2 text-xs font-medium uppercase tracking-wider text-fg-subtle">
        {nombreCategoria}
        {tambienAirFryer && (
          <span class="ml-1.5 normal-case tracking-normal text-fg-muted">· Air Fryer</span>
        )}
      </p>

      <h3 class="font-display text-xl font-semibold leading-snug tracking-tight text-fg line-clamp-2 group-hover:text-accent">
        {title}
      </h3>

      {descripcion && (
        <p class="mt-2 text-sm leading-relaxed text-fg-muted line-clamp-2">{descripcion}</p>
      )}

      <div class="mt-4 flex items-center gap-4 text-xs text-fg-muted">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-3.13a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          {porciones} {porciones === 1 ? 'porción' : 'porciones'}
        </span>

        {calorias && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"></path>
            </svg>
            {calorias} kcal
          </span>
        )}

        <span class={`ml-auto inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium ${
          dificultad === 'facil'
            ? 'bg-accent-soft text-accent'
            : dificultad === 'media'
            ? 'bg-accent-soft text-accent'
            : 'bg-accent-soft text-accent'
        }`}>
          {dificultadLabel}
        </span>
      </div>

      {tags && tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1.5">
          {tags.slice(0, 3).map(tag => (
            <span class="rounded-full bg-canvas px-2 py-0.5 text-[11px] text-fg-muted">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
