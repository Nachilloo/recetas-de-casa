---
import RecetaCardCompact from './RecetaCardCompact.astro';
import { categorias } from '../content/config';
import type { FiltroTiempoURL } from '../lib/recetaTiempo';
import { buscarHref, textoFiltroTiempo } from '../lib/buscarQuery';

export interface Props {
  recetas: any[];
  termino: string;
  categoria?: string;
  /** Filtro de tiempo activo (desde ?tiempo=) */
  tiempoFiltro?: FiltroTiempoURL;
  totalRecetas: number;
}

const {
  recetas,
  termino,
  categoria = '',
  tiempoFiltro = 'all',
  totalRecetas,
} = Astro.props;

const catValida =
  categoria && categoria in categorias ? categoria : '';
const tiempoTxt = textoFiltroTiempo(tiempoFiltro);

let tituloResultados = 'Todas las recetas';
if (termino.trim()) tituloResultados = `🔍 Resultados para "${termino.trim()}"`;
else if (tiempoTxt) tituloResultados = `⏱️ ${tiempoTxt}`;
const getCategoriaEmoji = (cat: string) => {
  const iconos: { [key: string]: string } = {
    'arroz-paellas': '🥘',
    'tortillas-pasta': '🥚',
    'sopas-cremas': '🍲',
    'carnes-aves': '🍖',
    'pescados-mariscos': '🐟',
    'pan-masas': '🥖',
    'postres': '🍰',
    'ensaladas-tapas': '🥗',
    'air-fryer': '🍗'
  };
  return iconos[cat] || '🍽️';
};
---

<div class="search-results">
  <!-- Información de resultados -->
  <div class="mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold text-gray-900">
        {tituloResultados}
        {catValida ? (
          <span class="text-lg font-normal text-gray-600 ml-2">
            en {categorias[catValida as keyof typeof categorias]}
          </span>
        ) : null}
      </h2>
      <span class="text-sm text-gray-500">
        {totalRecetas} receta{totalRecetas !== 1 ? 's' : ''} encontrada{totalRecetas !== 1 ? 's' : ''}
      </span>
    </div>

    <!-- Filtros activos -->
    {(termino.trim() || catValida || tiempoFiltro !== 'all') && (
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="text-sm text-gray-600">Filtros activos:</span>

        {catValida ? (
          <div class="flex items-center bg-orange-100 text-orange-800 px-3 py-1 rounded-full text-sm">
            <span class="mr-1">{getCategoriaEmoji(catValida)}</span>
            <span>{categorias[catValida as keyof typeof categorias]}</span>
            <a
              href={buscarHref({
                termino,
                tiempo: tiempoFiltro !== 'all' ? tiempoFiltro : undefined,
              })}
              class="ml-2 hover:text-orange-600"
              aria-label="Quitar categoría"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </a>
          </div>
        ) : null}

        {tiempoTxt ? (
          <div class="flex items-center bg-amber-100 text-amber-900 px-3 py-1 rounded-full text-sm">
            <span>⏱️ {tiempoTxt}</span>
            <a
              href={buscarHref({
                termino,
                categoria: catValida || undefined,
                tiempo: 'all',
              })}
              class="ml-2 hover:text-amber-700"
              aria-label="Quitar filtro de tiempo"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </a>
          </div>
        ) : null}

        {termino.trim() ? (
          <div class="flex items-center bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">
            <span>"{termino.trim()}"</span>
            <a
              href={buscarHref({
                categoria: catValida || undefined,
                tiempo: tiempoFiltro !== 'all' ? tiempoFiltro : undefined,
              })}
              class="ml-2 hover:text-blue-600"
              aria-label="Quitar búsqueda"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </a>
          </div>
        ) : null}

        <a href="/buscar" class="text-sm text-gray-500 hover:text-gray-700 underline">
          Limpiar todos
        </a>
      </div>
    )}
  </div>

  <!-- Lista de resultados -->
  {totalRecetas === 0 ? (
    <div class="text-center py-12">
      <div class="text-6xl mb-4">🔍</div>
      <h3 class="text-xl font-semibold text-gray-700 mb-2">No se encontraron recetas</h3>
      <p class="text-gray-500 mb-6">
        {termino.trim()
          ? `No hay recetas que coincidan con "${termino.trim()}"`
          : catValida
            ? `No hay recetas en la categoría ${categorias[catValida as keyof typeof categorias]}`
            : tiempoTxt
              ? `Ninguna receta encaja en «${tiempoTxt}». Prueba otro intervalo o limpia el filtro.`
              : 'No hay recetas disponibles'
        }
      </p>
      <div class="space-x-4">
        <a href="/buscar" class="inline-block bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-lg font-medium transition-colors duration-200">
          Ver todas las recetas
        </a>
        <a href="/" class="inline-block bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-3 rounded-lg font-medium transition-colors duration-200">
          Volver al inicio
        </a>
      </div>
    </div>
  ) : (
    <div class="grid gap-4">
      {recetas.map(receta => (
        <RecetaCardCompact receta={receta} />
      ))}
    </div>
  )}
</div>