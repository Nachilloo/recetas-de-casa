---
import RecetaCardCompact from './RecetaCardCompact.astro';
import { categorias } from '../content/config';
import type { FiltroTiempoURL } from '../lib/recetaTiempo';
import { buscarHref, textoFiltroTiempo } from '../lib/buscarQuery';

export interface Props {
  recetas: any[];
  termino: string;
  categoria?: string;
  /** Filtro de tiempo activo (desde ?tiempo=) */
  tiempoFiltro?: FiltroTiempoURL;
  totalRecetas: number;
}

const {
  recetas,
  termino,
  categoria = '',
  tiempoFiltro = 'all',
  totalRecetas,
} = Astro.props;

const catValida =
  categoria && categoria in categorias ? categoria : '';
const tiempoTxt = textoFiltroTiempo(tiempoFiltro);

let tituloResultados = 'Todas las recetas';
if (termino.trim()) tituloResultados = `Resultados para "${termino.trim()}"`;
else if (tiempoTxt) tituloResultados = tiempoTxt;
---

<div class="search-results">
  <div class="mb-6">
    <div class="flex items-end justify-between gap-4 mb-4">
      <h2 class="font-display text-2xl font-semibold tracking-tight text-fg sm:text-3xl">
        {tituloResultados}
        {catValida ? (
          <span class="text-base font-normal text-fg-muted ml-2">
            en {categorias[catValida as keyof typeof categorias]}
          </span>
        ) : null}
      </h2>
      <span class="shrink-0 text-sm text-fg-muted tabular-nums">
        {totalRecetas} {totalRecetas === 1 ? 'receta' : 'recetas'}
      </span>
    </div>

    {(termino.trim() || catValida || tiempoFiltro !== 'all') && (
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="text-xs uppercase tracking-wider text-fg-subtle">Filtros activos</span>

        {catValida ? (
          <div class="flex items-center bg-accent-soft text-accent px-3 py-1 rounded-full text-sm">
            <span>{categorias[catValida as keyof typeof categorias]}</span>
            <a
              href={buscarHref({
                termino,
                tiempo: tiempoFiltro !== 'all' ? tiempoFiltro : undefined,
              })}
              class="ml-2 transition-colors hover:text-[var(--color-accent-hover)]"
              aria-label="Quitar categoría"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </a>
          </div>
        ) : null}

        {tiempoTxt ? (
          <div class="flex items-center border border-border bg-canvas text-fg px-3 py-1 rounded-full text-sm">
            <span>{tiempoTxt}</span>
            <a
              href={buscarHref({
                termino,
                categoria: catValida || undefined,
                tiempo: 'all',
              })}
              class="ml-2 text-fg-muted transition-colors hover:text-accent"
              aria-label="Quitar filtro de tiempo"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </a>
          </div>
        ) : null}

        {termino.trim() ? (
          <div class="flex items-center border border-border bg-canvas text-fg px-3 py-1 rounded-full text-sm">
            <span>"{termino.trim()}"</span>
            <a
              href={buscarHref({
                categoria: catValida || undefined,
                tiempo: tiempoFiltro !== 'all' ? tiempoFiltro : undefined,
              })}
              class="ml-2 text-fg-muted transition-colors hover:text-accent"
              aria-label="Quitar búsqueda"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </a>
          </div>
        ) : null}

        <a href="/buscar" class="text-sm text-fg-muted underline-offset-2 hover:text-accent hover:underline">
          Limpiar todos
        </a>
      </div>
    )}
  </div>

  {totalRecetas === 0 ? (
    <div class="rounded-[var(--radius-lg)] border border-border bg-surface px-6 py-16 text-center">
      <svg class="mx-auto mb-4 h-10 w-10 text-fg-subtle" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <h3 class="font-display text-xl font-semibold text-fg">No se encontraron recetas</h3>
      <p class="mt-2 text-sm text-fg-muted">
        {termino.trim()
          ? `No hay recetas que coincidan con "${termino.trim()}".`
          : catValida
            ? `No hay recetas en la categoría ${categorias[catValida as keyof typeof categorias]}.`
            : tiempoTxt
              ? `Ninguna receta encaja en «${tiempoTxt}». Prueba otro intervalo o limpia el filtro.`
              : 'No hay recetas disponibles.'
        }
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/buscar" class="inline-flex items-center justify-center rounded-[var(--radius)] bg-accent px-5 py-2.5 text-sm font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover">
          Ver todas las recetas
        </a>
        <a href="/" class="inline-flex items-center justify-center rounded-[var(--radius)] border border-border bg-canvas px-5 py-2.5 text-sm font-medium text-fg transition-colors hover:border-accent hover:text-accent">
          Volver al inicio
        </a>
      </div>
    </div>
  ) : (
    <div class="grid gap-4">
      {recetas.map(receta => (
        <RecetaCardCompact receta={receta} />
      ))}
    </div>
  )}
</div>
