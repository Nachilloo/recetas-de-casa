---
interface Props {
  placeholder?: string;
  className?: string;
}

const { placeholder = "Buscar por ingrediente, nombre...", className = "" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<div class:list={["hero-search w-full max-w-xl mx-auto text-left", className]}>
  <form action={`${baseUrl}buscar`} method="get" class="space-y-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-stretch rounded-full shadow-lg border border-white/25 bg-white/95 focus-within:ring-2 focus-within:ring-orange-200/90 overflow-hidden sm:rounded-2xl sm:overflow-visible sm:bg-transparent sm:border-0 sm:shadow-none sm:focus-within:ring-0">
      <label class="sr-only" for="hero-search-q">Buscar recetas</label>
      <input
        id="hero-search-q"
        type="search"
        name="q"
        placeholder={placeholder}
        class="w-full px-6 py-4 text-base text-gray-800 placeholder-gray-500 bg-transparent border-0 focus:outline-none focus:ring-0 sm:rounded-2xl sm:bg-white sm:border sm:border-gray-200 sm:shadow-md"
      />
      <button
        type="submit"
        class="shrink-0 inline-flex justify-center items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white px-8 py-4 font-semibold transition-colors sm:rounded-2xl sm:shadow-md whitespace-nowrap"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Buscar
      </button>
    </div>

    <div class="text-center space-y-2">
      <p class="text-white/85 text-xs font-medium tracking-wide uppercase">O por tiempo de cocina</p>
      <div class="flex flex-wrap justify-center gap-2">
        <button
          type="submit"
          name="tiempo"
          value="lt30"
          class="hero-tiempo-btn px-4 py-2.5 rounded-full text-sm font-semibold border border-white/35 bg-white/10 text-white backdrop-blur-sm hover:bg-white/20 hover:border-white/55 transition-colors"
        >
          &lt; 30&nbsp;min
        </button>
        <button
          type="submit"
          name="tiempo"
          value="m30_60"
          class="hero-tiempo-btn px-4 py-2.5 rounded-full text-sm font-semibold border border-white/35 bg-white/10 text-white backdrop-blur-sm hover:bg-white/20 hover:border-white/55 transition-colors"
        >
          30–60&nbsp;min
        </button>
        <button
          type="submit"
          name="tiempo"
          value="gt60"
          class="hero-tiempo-btn px-4 py-2.5 rounded-full text-sm font-semibold border border-white/35 bg-white/10 text-white backdrop-blur-sm hover:bg-white/20 hover:border-white/55 transition-colors"
        >
          &gt; 60&nbsp;min
        </button>
        <a
          href={`${baseUrl}buscar`}
          class="hero-tiempo-btn inline-flex items-center justify-center px-4 py-2.5 rounded-full text-sm font-semibold border border-white/40 bg-white/90 text-orange-700 hover:bg-white transition-colors shadow-sm no-underline"
        >
          Todas
        </a>
      </div>
    </div>
  </form>
</div>
