---
import LogoMark from './LogoMark.astro';
import UserMenu from './UserMenu.astro';

const baseUrl = import.meta.env.BASE_URL;
const user = Astro.locals.user;
const profile = Astro.locals.profile;
---

<header
  class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur-md supports-[backdrop-filter]:bg-surface/90"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle sr-only"
      aria-controls="mobile-nav-panel"
    />

    <div class="flex h-16 items-center justify-between gap-3">
      <a
        href={baseUrl}
        class="flex min-w-0 max-w-[60%] items-center gap-2.5 text-fg transition-colors hover:text-accent sm:max-w-none sm:gap-3"
        aria-label="Recetas de Casa, inicio"
      >
        <LogoMark class="h-8 sm:h-9" />
        <span class="font-display truncate text-base font-semibold tracking-tight sm:text-lg sm:truncate-none">
          Recetas de Casa
        </span>
      </a>

      <nav
        class="hidden flex-1 items-center justify-center gap-0.5 md:flex lg:gap-1"
        aria-label="Principal"
      >
        <a
          href={baseUrl}
          class="rounded-lg px-2.5 py-2 text-sm font-medium text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent lg:px-3"
          >Inicio</a
        >
        <a
          href={`${baseUrl}recetas/`}
          class="rounded-lg px-2.5 py-2 text-sm font-medium text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent lg:px-3"
          >Recetas</a
        >
        <a
          href={`${baseUrl}buscar`}
          class="rounded-lg px-2.5 py-2 text-sm font-medium text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent lg:px-3"
          >Buscar</a
        >
        <a
          href={`${baseUrl}precios`}
          class="rounded-lg px-2.5 py-2 text-sm font-medium text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent lg:px-3"
          >Planes</a
        >
        <details class="relative">
          <summary
            class="flex cursor-pointer list-none items-center gap-0.5 rounded-lg px-2.5 py-2 text-sm font-medium text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent lg:px-3 [&::-webkit-details-marker]:hidden"
          >
            Ideas
            <svg class="h-4 w-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <div
            class="absolute left-0 top-full z-50 mt-1 max-h-[min(70vh,22rem)] w-52 overflow-y-auto overscroll-contain rounded-xl border border-border bg-surface py-1 shadow-lg lg:left-1/2 lg:w-56 lg:-translate-x-1/2"
          >
            <a
              href={`${baseUrl}recetas-faciles/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Recetas fáciles</a
            >
            <a
              href={`${baseUrl}cenas-rapidas/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Cenas rápidas</a
            >
            <a
              href={`${baseUrl}comidas-rapidas/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Comidas rápidas</a
            >
            <a
              href={`${baseUrl}recetas-con-pollo/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Recetas con pollo</a
            >
            <a
              href={`${baseUrl}recetas-baratas/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Recetas baratas</a
            >
            <a
              href={`${baseUrl}recetas-airfryer/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Air fryer</a
            >
            <a
              href={`${baseUrl}postres-faciles/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Postres fáciles</a
            >
            <a
              href={`${baseUrl}recetas-saludables/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Recetas saludables</a
            >
            <a
              href={`${baseUrl}recetas-para-ninos/`}
              class="block px-4 py-2.5 text-sm text-fg transition-colors hover:bg-accent-soft hover:text-accent"
              >Recetas para niños</a
            >
          </div>
        </details>
        <a
          href={`${baseUrl}menu-semanal`}
          class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-canvas px-2.5 py-2 text-sm font-medium text-fg transition-colors hover:border-accent hover:text-accent lg:ml-0.5 lg:px-3"
        >
          <svg class="h-4 w-4 shrink-0 text-fg-muted" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="hidden lg:inline">Menú semanal</span>
          <span class="lg:hidden">Menú</span>
        </a>
      </nav>

      <div class="relative z-20 flex shrink-0 items-center gap-1">
        {/* Toggle tema (desktop + móvil) */}
        <button
          id="theme-toggle"
          type="button"
          class="rounded-lg p-2 text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent touch-manipulation"
          aria-label="Cambiar tema"
          title="Cambiar tema"
        >
          <svg class="theme-icon-light h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="4" stroke-linecap="round" stroke-linejoin="round"></circle>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41"></path>
          </svg>
          <svg class="theme-icon-dark h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>

        {/* Auth UI (desktop) */}
        <div class="hidden md:flex md:items-center md:gap-1.5 md:pl-1.5">
          <span class="hidden h-5 w-px bg-border lg:inline-block" aria-hidden="true"></span>
          {user ? (
            <UserMenu profile={profile} email={user.email ?? ''} />
          ) : (
            <>
              <a
                href={`${baseUrl}login`}
                class="rounded-lg px-2.5 py-2 text-sm font-medium text-fg-muted transition-colors hover:text-accent lg:px-3"
              >
                Iniciar sesión
              </a>
              <a
                href={`${baseUrl}registro`}
                class="rounded-lg border border-accent px-3 py-2 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-[var(--color-accent-contrast)]"
              >
                Crear cuenta
              </a>
            </>
          )}
        </div>

        {/* Móvil: buscar + hamburguesa */}
        <a
          href={`${baseUrl}buscar`}
          class="rounded-lg p-2 text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent md:hidden touch-manipulation"
          aria-label="Buscar recetas"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </a>
        <label
          for="nav-toggle"
          class="cursor-pointer rounded-lg p-2 text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent md:hidden touch-manipulation"
        >
          <span class="sr-only">Abrir o cerrar menú</span>
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </label>
      </div>
    </div>

    <nav
      id="mobile-nav-panel"
      class="mobile-nav-panel border-t border-border bg-surface md:hidden"
      aria-label="Navegación móvil"
    >
      <div class="flex max-h-[min(85vh,40rem)] flex-col gap-0.5 overflow-y-auto py-3">
        <a
          href={baseUrl}
          class="rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
          >Inicio</a
        >
        <a
          href={`${baseUrl}recetas/`}
          class="rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
          >Recetas</a
        >
        <a
          href={`${baseUrl}buscar`}
          class="rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
          >Buscar</a
        >
        <a
          href={`${baseUrl}precios`}
          class="rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
          >Planes</a
        >
        <p class="px-3 pt-2 text-xs font-semibold uppercase tracking-wider text-fg-subtle">Ideas</p>
        <a
          href={`${baseUrl}recetas-faciles/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Recetas fáciles</a
        >
        <a
          href={`${baseUrl}cenas-rapidas/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Cenas rápidas</a
        >
        <a
          href={`${baseUrl}recetas-con-pollo/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Recetas con pollo</a
        >
        <a
          href={`${baseUrl}recetas-baratas/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Recetas baratas</a
        >
        <a
          href={`${baseUrl}comidas-rapidas/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Comidas rápidas</a
        >
        <a
          href={`${baseUrl}recetas-airfryer/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Air fryer</a
        >
        <a
          href={`${baseUrl}postres-faciles/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Postres fáciles</a
        >
        <a
          href={`${baseUrl}recetas-saludables/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Recetas saludables</a
        >
        <a
          href={`${baseUrl}recetas-para-ninos/`}
          class="rounded-lg px-3 py-2 pl-5 text-sm text-fg-muted transition-colors hover:bg-accent-soft hover:text-accent"
          >Recetas para niños</a
        >
        <a
          href={`${baseUrl}menu-semanal`}
          class="mt-1 inline-flex items-center gap-2 rounded-lg border border-border bg-canvas px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:border-accent hover:text-accent"
        >
          <svg class="h-4 w-4 text-fg-muted" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          Menú semanal
        </a>

        {user ? (
          <div class="mt-3 space-y-0.5 border-t border-border pt-3">
            <p class="px-3 pt-1 text-xs font-semibold uppercase tracking-wider text-fg-subtle">
              Mi cuenta
            </p>
            <a
              href={`${baseUrl}perfil/favoritos`}
              class="block rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
            >
              Mis favoritos
            </a>
            <a
              href={`${baseUrl}perfil/colecciones`}
              class="block rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
            >
              Mis colecciones
            </a>
            <a
              href={`${baseUrl}perfil/cuenta`}
              class="block rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
            >
              Cuenta
            </a>
            <a
              href={`${baseUrl}perfil/plan`}
              class="block rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-accent-soft hover:text-accent"
            >
              Plan
            </a>
            <form action={`${baseUrl}api/auth/logout`} method="post" class="px-3 pt-2">
              <button
                type="submit"
                class="w-full rounded-lg border border-border px-3 py-2 text-center text-sm font-medium text-fg-muted transition-colors hover:border-accent hover:text-accent"
              >
                Cerrar sesión
              </button>
            </form>
          </div>
        ) : (
          <div class="mt-3 grid grid-cols-2 gap-2 border-t border-border pt-3">
            <a
              href={`${baseUrl}login`}
              class="rounded-lg border border-border px-3 py-2.5 text-center text-sm font-medium text-fg transition-colors hover:border-accent hover:text-accent"
            >
              Iniciar sesión
            </a>
            <a
              href={`${baseUrl}registro`}
              class="rounded-lg border border-accent bg-accent px-3 py-2.5 text-center text-sm font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover"
            >
              Crear cuenta
            </a>
          </div>
        )}
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var LABELS = {
      dark: "Tema: oscuro (pulsar para modo claro)",
      light: "Tema: claro (pulsar para modo oscuro)",
    };

    function getStoredTheme() {
      try {
        if (localStorage.getItem("theme") === "light") return "light";
      } catch (e) {}
      return "dark";
    }

    function applyTheme(mode) {
      var next = mode === "light" ? "light" : "dark";
      try {
        localStorage.setItem("theme", next);
      } catch (e) {}
      document.documentElement.setAttribute("data-theme", next);
      var themeButton = document.getElementById("theme-toggle");
      if (themeButton) {
        themeButton.setAttribute("aria-label", LABELS[next]);
        themeButton.setAttribute("title", LABELS[next]);
      }
    }

    function syncThemeFromStorage() {
      applyTheme(getStoredTheme());
    }

    /* View Transitions: el DOM del header se sustituye; un solo listener en document evita botones “muertos”. */
    if (!window.__recetasThemeDelegate) {
      window.__recetasThemeDelegate = true;
      document.addEventListener("click", function (e) {
        var t = e.target;
        if (!t || !t.closest) return;
        if (!t.closest("#theme-toggle")) return;
        var cur = getStoredTheme();
        applyTheme(cur === "dark" ? "light" : "dark");
      });
    }

    if (!window.__recetasNavPanelDelegate) {
      window.__recetasNavPanelDelegate = true;
      document.addEventListener("click", function (e) {
        var t = e.target;
        if (!t || !t.closest) return;
        if (!t.closest("#mobile-nav-panel a")) return;
        var toggleNav = document.getElementById("nav-toggle");
        if (toggleNav) toggleNav.checked = false;
      });
    }

    if (!window.__recetasAstroPageLoadTheme) {
      window.__recetasAstroPageLoadTheme = true;
      document.addEventListener("astro:page-load", syncThemeFromStorage);
    }

    syncThemeFromStorage();
  })();
</script>

<style>
  .mobile-nav-panel {
    display: none;
  }
  #nav-toggle:checked ~ #mobile-nav-panel {
    display: block;
  }
  @media (min-width: 768px) {
    #mobile-nav-panel {
      display: none !important;
    }
  }

  details summary::-webkit-details-marker {
    display: none;
  }
</style>
