---
import type { FiltroTiempoURL } from '../lib/recetaTiempo';
import { buscarHref } from '../lib/buscarQuery';

export interface Props {
  termino?: string;
  categoria?: string;
  tiempoActivo?: FiltroTiempoURL;
  className?: string;
}

const { termino = '', categoria = '', tiempoActivo = 'all', className = '' } = Astro.props;

const items: { key: FiltroTiempoURL; label: string }[] = [
  { key: 'lt30', label: '< 30 min' },
  { key: 'm30_60', label: '30–60 min' },
  { key: 'gt60', label: '> 60 min' },
  { key: 'all', label: 'Todas' },
];
---

<div class:list={["flex flex-wrap justify-center gap-2", className]}>
  {
    items.map(({ key, label }) => (
      <a
        href={buscarHref({
          termino,
          categoria: categoria || undefined,
          tiempo: key,
        })}
        class:list={[
          'rounded-full border px-4 py-2 text-sm font-medium transition-colors',
          tiempoActivo === key
            ? 'border-accent bg-accent text-[var(--color-accent-contrast)]'
            : 'border-border bg-surface text-fg-muted hover:border-accent hover:text-accent',
        ]}
      >
        {label}
      </a>
    ))
  }
</div>
