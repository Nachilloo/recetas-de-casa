---
import Layout from '../layouts/Layout.astro';
import RecetaCard from './RecetaCard.astro';
import type { Receta } from '../lib/types';

export interface FaqItem {
  pregunta: string;
  respuesta: string;
}

export interface EnlaceInterno {
  href: string;
  texto: string;
}

export interface Props {
  metaTitle: string;
  metaDescription: string;
  canonicalPath: string;
  h1: string;
  badgeText: string;
  introParagraphs: string[];
  recetas: Receta[];
  faqs: FaqItem[];
  enlacesInternos: EnlaceInterno[];
}

const {
  metaTitle,
  metaDescription,
  canonicalPath,
  h1,
  badgeText,
  introParagraphs,
  recetas,
  faqs,
  enlacesInternos,
} = Astro.props;

const base = Astro.site?.href ?? 'http://localhost:4321/';
const canonicalUrl = new URL(canonicalPath.replace(/^\//, ''), base).href;

const [introLead, ...introRest] = introParagraphs;
const introHasMore = introRest.length > 0;

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.pregunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.respuesta,
    },
  })),
};
---

<Layout title={metaTitle} description={metaDescription} canonicalUrl={canonicalUrl} type="website">
  <script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify(faqLd)} />

  <main class="min-h-screen bg-canvas">
    <div class="mx-auto max-w-7xl px-6 pt-10 pb-6">
      <article>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-accent">
          Recetas de Casa
        </p>
        <h1 class="mb-4 text-3xl font-black leading-tight text-fg md:text-4xl lg:text-5xl">
          {h1}
        </h1>
        <p
          class="mb-8 inline-flex flex-wrap items-center gap-2 rounded-full border border-border bg-accent-soft px-4 py-2 text-sm font-semibold text-accent"
        >
          {badgeText}
        </p>

        {
          introParagraphs.length > 0 && (
            <div
              class="prose prose-lg max-w-none prose-headings:font-semibold prose-headings:text-fg prose-p:mt-0 prose-p:leading-relaxed prose-p:text-fg-muted prose-strong:text-fg"
            >
              <p>{introLead}</p>
              {introHasMore ? (
                <>
                  <div id="seo-intro-more" class="seo-intro-more hidden space-y-4">
                    {introRest.map((p) => (
                      <p>{p}</p>
                    ))}
                  </div>
                  <p class="not-prose mb-0 mt-3">
                    <button
                      type="button"
                      id="seo-intro-toggle"
                      class="text-sm font-semibold text-accent underline-offset-2 transition-colors hover:text-[var(--color-accent-hover)] hover:underline"
                      aria-expanded="false"
                      aria-controls="seo-intro-more"
                    >
                      Leer más
                    </button>
                  </p>
                </>
              ) : null}
            </div>
          )
        }
      </article>
    </div>

    <section class="mx-auto max-w-7xl px-6 pb-12" aria-labelledby="recetas-listado">
      <h2 id="recetas-listado" class="sr-only">
        Recetas seleccionadas
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {recetas.map((receta) => (
          <RecetaCard receta={receta} />
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-6 pb-6">
      <h2 class="mb-4 text-xl font-bold text-fg">Sigue explorando</h2>
      <ul class="flex flex-wrap gap-3">
        {enlacesInternos.map((e) => (
          <li>
            <a
              href={e.href}
              class="inline-block rounded-full border border-border bg-surface px-4 py-2 text-sm font-medium text-fg transition-colors hover:border-accent hover:bg-accent-soft hover:text-accent"
            >
              {e.texto}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mx-auto max-w-4xl px-6 pb-16" aria-labelledby="faq-titulo">
      <h2 id="faq-titulo" class="mb-6 text-2xl font-bold text-fg">
        Preguntas frecuentes
      </h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl border border-border bg-surface shadow-sm open:shadow-md">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-semibold text-fg">
              <span>{f.pregunta}</span>
              <span class="shrink-0 text-accent transition-transform group-open:rotate-180">▼</span>
            </summary>
            <div class="border-t border-border px-5 pb-4 pt-0 leading-relaxed text-fg-muted">
              <p class="pt-3">{f.respuesta}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    (function () {
      if (window.__seoIntroReadMore) return;
      window.__seoIntroReadMore = true;
      document.addEventListener("click", function (e) {
        var t = e.target;
        if (!t || !t.closest) return;
        var btn = t.closest("#seo-intro-toggle");
        if (!btn) return;
        var more = document.getElementById("seo-intro-more");
        if (!more) return;
        more.classList.toggle("hidden");
        var expanded = !more.classList.contains("hidden");
        btn.setAttribute("aria-expanded", expanded ? "true" : "false");
        btn.textContent = expanded ? "Leer menos" : "Leer más";
      });
    })();
  </script>
</Layout>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
