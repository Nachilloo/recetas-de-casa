---
const baseUrl = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-border bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <p class="font-display text-lg font-semibold text-fg">Recetas de Casa</p>
        <p class="mt-2 max-w-md text-sm leading-relaxed text-fg-muted">
          Recetas caseras y tradicionales, con enfoque en cocina española del día a día.
        </p>
      </div>
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-fg-subtle">Explorar</h2>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href={`${baseUrl}recetas/`} class="text-fg-muted transition-colors hover:text-accent">Todas las recetas</a>
          </li>
          <li>
            <a href={`${baseUrl}buscar`} class="text-fg-muted transition-colors hover:text-accent">Buscar</a>
          </li>
          <li>
            <a href={`${baseUrl}menu-semanal`} class="text-fg-muted transition-colors hover:text-accent">Menú semanal</a>
          </li>
          <li>
            <a href={`${baseUrl}about/`} class="text-fg-muted transition-colors hover:text-accent">Sobre nosotros</a>
          </li>
        </ul>
      </div>
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-fg-subtle">Ideas</h2>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href={`${baseUrl}recetas-faciles/`} class="text-fg-muted transition-colors hover:text-accent">Recetas fáciles</a>
          </li>
          <li>
            <a href={`${baseUrl}cenas-rapidas/`} class="text-fg-muted transition-colors hover:text-accent">Cenas rápidas</a>
          </li>
          <li>
            <a href={`${baseUrl}comidas-rapidas/`} class="text-fg-muted transition-colors hover:text-accent">Comidas rápidas</a>
          </li>
          <li>
            <a href={`${baseUrl}recetas-con-pollo/`} class="text-fg-muted transition-colors hover:text-accent">Con pollo</a>
          </li>
          <li>
            <a href={`${baseUrl}recetas-baratas/`} class="text-fg-muted transition-colors hover:text-accent">Recetas baratas</a>
          </li>
          <li>
            <a href={`${baseUrl}recetas-airfryer/`} class="text-fg-muted transition-colors hover:text-accent">Air fryer</a>
          </li>
          <li>
            <a href={`${baseUrl}postres-faciles/`} class="text-fg-muted transition-colors hover:text-accent">Postres fáciles</a>
          </li>
          <li>
            <a href={`${baseUrl}recetas-saludables/`} class="text-fg-muted transition-colors hover:text-accent">Recetas saludables</a>
          </li>
          <li>
            <a href={`${baseUrl}recetas-para-ninos/`} class="text-fg-muted transition-colors hover:text-accent">Recetas para niños</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-10 flex flex-col gap-3 border-t border-border pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-fg-subtle">© {year} Recetas de Casa. Todos los derechos reservados.</p>
      <nav class="flex flex-wrap gap-4 text-xs text-fg-subtle" aria-label="Legal">
        <a href={`${baseUrl}precios`} class="transition-colors hover:text-accent">Precios</a>
        <a href={`${baseUrl}terminos`} class="transition-colors hover:text-accent">Términos</a>
        <a href={`${baseUrl}privacidad`} class="transition-colors hover:text-accent">Privacidad</a>
      </nav>
    </div>
  </div>
</footer>
