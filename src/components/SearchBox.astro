---
export interface Props {
  placeholder?: string;
  size?: 'sm' | 'md' | 'lg';
  showButton?: boolean;
  className?: string;
  /** Si es false, se puede enviar búsqueda vacía solo con otros query params */
  requireQuery?: boolean;
  /** Valor inicial para ?q= (p. ej. en /buscar) */
  initialQuery?: string;
  /** Conservar ?tiempo= y ?categoria= al reenviar el formulario desde /buscar */
  tiempoFiltro?: string;
  categoriaFiltro?: string;
}

const {
  placeholder = "Buscar recetas…",
  size = 'md',
  showButton = true,
  className = "",
  requireQuery = true,
  initialQuery = '',
  tiempoFiltro = '',
  categoriaFiltro = '',
} = Astro.props;

const inputSize = {
  sm: 'px-3 py-2 text-sm',
  md: 'px-4 py-3 text-base',
  lg: 'px-5 py-3.5 text-base',
};

const buttonSize = {
  sm: 'px-3 py-2 text-sm',
  md: 'px-5 py-3 text-base',
  lg: 'px-6 py-3.5 text-base',
};

const baseUrl = import.meta.env.BASE_URL;
---

<div class={`search-box ${className}`}>
  <form action={`${baseUrl}buscar`} method="get">
    {categoriaFiltro ? <input type="hidden" name="categoria" value={categoriaFiltro} /> : null}
    {tiempoFiltro && tiempoFiltro !== 'all' ? (
      <input type="hidden" name="tiempo" value={tiempoFiltro} />
    ) : null}
    <div class="flex items-stretch overflow-hidden rounded-[var(--radius-lg)] border border-border bg-surface focus-within:border-accent focus-within:ring-2 focus-within:ring-accent-soft">
      <span class="flex items-center pl-4 text-fg-subtle" aria-hidden="true">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </span>
      <input
        type="search"
        name="q"
        value={initialQuery}
        placeholder={placeholder}
        class={`flex-1 bg-transparent ${inputSize[size]} text-fg placeholder-fg-subtle focus:outline-none`}
        required={requireQuery ? true : undefined}
      />
      {showButton && (
        <button
          type="submit"
          class={`shrink-0 bg-accent ${buttonSize[size]} font-semibold text-[var(--color-accent-contrast)] transition-colors hover:bg-accent-hover`}
        >
          <span class="hidden sm:inline">Buscar</span>
          <svg class="h-5 w-5 sm:hidden" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
      )}
    </div>
  </form>
</div>
